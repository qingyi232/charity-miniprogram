/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', STHeiti, 'Microsoft Yahei', Tahoma, Simsun, sans-serif;
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
}

view, text, image {
  box-sizing: border-box;
}

scroll-view {
  max-width: 100vw;
}

.inline-icon {
  width: 24rpx;
  height: 24rpx;
  vertical-align: middle;
}

.more-arrow {
  width: 24rpx;
  height: 24rpx;
  vertical-align: middle;
}

/* 老者端全局样式变量 */
.elder-theme {
  --primary-color: #E8573A;
  --primary-light: #FFF5F0;
  --bg-warm: #FDF8F4;
  --text-large: 36rpx;
  --text-xlarge: 42rpx;
  --text-title: 48rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
}

/* 志愿者端全局样式变量 - 青绿公益风配色 */
.volunteer-theme {
  --primary-color: #2DB5A0;
  --primary-light: #E6F7F4;
  --primary-gradient-start: #43B89C;
  --primary-gradient-end: #20A88E;
  --bg-clean: #F2F8F6;
  --text-normal: 28rpx;
  --text-large: 32rpx;
  --radius-lg: 20rpx;
}

/* 通用工具类 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-gray { color: #999; }
.text-white { color: #fff; }

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.btn-primary-elder {
  background: linear-gradient(135deg, #E8573A, #D94425);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(232, 87, 58, 0.3);
}

.btn-primary-volunteer {
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* SVG 图标通用尺寸 */
.inline-icon {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
  margin-right: 4rpx;
}
.star-icon {
  width: 28rpx;
  height: 28rpx;
}
.check-icon {
  width: 24rpx;
  height: 24rpx;
}
.more-arrow {
  width: 24rpx;
  height: 24rpx;
  vertical-align: middle;
  margin-left: 4rpx;
}
