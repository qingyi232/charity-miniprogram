.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5EC 0%, #FDF8F4 40%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
  position: relative;
}

.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  opacity: 0.15;
}

.login-bg-img {
  width: 100%;
  height: 100%;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 50rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 60rpx;
}
.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(45, 181, 160, 0.3);
  border: 4rpx solid #2DB5A0;
}
.logo-img {
  width: 100%;
  height: 100%;
}
.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}
.app-slogan {
  font-size: 26rpx;
  color: #999;
  letter-spacing: 2rpx;
}

.role-select {
  margin-bottom: 60rpx;
}
.role-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}
.role-cards {
  display: flex;
  gap: 24rpx;
}
.role-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid transparent;
  position: relative;
  transition: all 0.3s;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.role-card.selected {
  border-color: #E8573A;
  box-shadow: 0 8rpx 24rpx rgba(232, 87, 58, 0.15);
}
.volunteer-card.selected {
  border-color: #2DB87B;
  box-shadow: 0 8rpx 24rpx rgba(45, 184, 123, 0.15);
}
.role-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.elder-icon-bg {
  background: linear-gradient(135deg, #FFF5EC, #FFCCBC);
}
.volunteer-icon-bg {
  background: linear-gradient(135deg, #E8F8EF, #A5D6A7);
}
.role-emoji {
  width: 48rpx;
  height: 48rpx;
}
.role-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.role-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}
.check-mark {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E8573A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}
.volunteer-card .check-mark {
  background: #2DB87B;
}

.login-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.wx-login-btn {
  width: 100%;
  background: linear-gradient(135deg, #E8573A, #D42A1A) !important;
  color: #fff !important;
  border-radius: 50rpx !important;
  padding: 26rpx 0 !important;
  font-size: 34rpx !important;
  font-weight: 600 !important;
  border: none !important;
  box-shadow: 0 8rpx 24rpx rgba(232, 87, 58, 0.3);
}
.wx-login-btn[disabled] {
  background: #ccc !important;
  box-shadow: none;
}
.agreement {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 24rpx;
}
