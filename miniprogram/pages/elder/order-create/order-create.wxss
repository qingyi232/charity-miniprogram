.create-page {
  min-height: 100vh;
  background: #FDF8F4;
  padding: 30rpx;
  padding-bottom: 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.form-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 36rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.elder-input {
  font-size: 32rpx !important;
  padding: 24rpx 20rpx !important;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  background: #FAFAFA;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  line-height: 1.4;
}

.form-input {
  font-size: 32rpx;
  padding: 24rpx 20rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  background: #FAFAFA;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  line-height: 1.4;
}

.form-textarea {
  min-height: 160rpx;
  width: 100%;
}

.char-count {
  font-size: 22rpx;
  color: #ccc;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  width: 28rpx;
  height: 28rpx;
  color: #999;
}

/* 需求类型网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  width: calc(33.33% - 12rpx);
  box-sizing: border-box;
}

.category-item.active {
  border-color: #E8573A;
  background: #FFF5F0;
}

.category-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #E8573A;
  font-weight: 600;
}

/* 紧急程度 */
.urgency-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.urgency-star {
  opacity: 0.25;
  transition: all 0.2s;
}

.urgency-star.active {
  opacity: 1;
  transform: scale(1.15);
}

.urgency-star .star-icon {
  width: 52rpx;
  height: 52rpx;
}

.urgency-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 提交按钮 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 50rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FDF8F4;
}

.submit-btn {
  background: linear-gradient(135deg, #E8573A, #D42A1A);
  color: #fff;
  border-radius: 50rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(232, 87, 58, 0.3);
}
