<view class="edit-page elder-theme">
  <scroll-view scroll-y class="edit-scroll">
    <view class="scroll-inner">
    <!-- 头像 -->
    <view class="avatar-section" bindtap="changeAvatar">
      <image class="edit-avatar" src="{{userInfo.avatar || '/static/images/default-avatar.svg'}}" mode="aspectFill" />
      <text class="avatar-hint">点击更换头像</text>
    </view>

    <!-- 基本信息 -->
    <view class="form-card">
      <view class="card-title">基本信息</view>

      <view class="form-item">
        <text class="form-label">昵称</text>
        <input class="form-input" placeholder="请输入昵称"
               value="{{userInfo.nickname}}" bindinput="onInput" data-field="nickname" />
      </view>

      <view class="form-item">
        <text class="form-label">真实姓名</text>
        <input class="form-input" placeholder="请输入真实姓名"
               value="{{userInfo.name}}" bindinput="onInput" data-field="name" />
      </view>

      <view class="form-item">
        <text class="form-label">年龄</text>
        <input class="form-input" placeholder="请输入年龄" type="number"
               value="{{userInfo.age}}" bindinput="onInput" data-field="age" />
      </view>

      <view class="form-item">
        <text class="form-label">性别</text>
        <picker mode="selector" range="{{genderList}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <view class="form-picker">
            <text>{{genderList[genderIndex] || '请选择'}}</text>
            <image class="picker-arrow" src="/static/icons/chevron-down.svg" mode="aspectFit" />
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" placeholder="请输入手机号" type="number"
               value="{{userInfo.phone}}" bindinput="onInput" data-field="phone" maxlength="11" />
      </view>
    </view>

    <!-- 地址信息 -->
    <view class="form-card">
      <view class="card-title">地址信息</view>

      <view class="form-item" bindtap="chooseAddress">
        <text class="form-label">住址</text>
        <view class="form-picker">
          <text>{{userInfo.address || '点击选择住址'}}</text>
          <image class="picker-arrow" src="/static/icons/location.svg" mode="aspectFit" />
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">详细地址</text>
        <input class="form-input" placeholder="门牌号、楼栋等"
               value="{{userInfo.addressDetail}}" bindinput="onInput" data-field="addressDetail" />
      </view>
    </view>

    <!-- 健康基础 -->
    <view class="form-card">
      <view class="card-title">健康基础</view>

      <view class="form-item">
        <text class="form-label">身高(cm)</text>
        <input class="form-input" placeholder="请输入身高" type="digit"
               value="{{userInfo.height}}" bindinput="onInput" data-field="height" />
      </view>

      <view class="form-item">
        <text class="form-label">体重(kg)</text>
        <input class="form-input" placeholder="请输入体重" type="digit"
               value="{{userInfo.weight}}" bindinput="onInput" data-field="weight" />
      </view>

      <view class="form-item">
        <text class="form-label">既往病史</text>
        <textarea class="form-textarea" placeholder="如高血压、糖尿病等（选填）"
                  value="{{userInfo.medicalHistory}}" bindinput="onInput" data-field="medicalHistory"
                  auto-height maxlength="200" />
      </view>
    </view>

    <!-- 紧急联系人 -->
    <view class="form-card">
      <view class="card-title-row">
        <text class="card-title">紧急联系人</text>
        <view class="add-btn" bindtap="addContact">
          <image class="add-icon" src="/static/icons/plus.svg" mode="aspectFit" />
          <text>添加</text>
        </view>
      </view>

      <view class="contact-item" wx:for="{{emergencyContacts}}" wx:key="index">
        <view class="contact-fields">
          <input class="contact-input" placeholder="姓名"
                 value="{{item.name}}" bindinput="onContactInput" data-index="{{index}}" data-field="name" />
          <input class="contact-input" placeholder="电话" type="number"
                 value="{{item.phone}}" bindinput="onContactInput" data-index="{{index}}" data-field="phone" maxlength="11" />
          <input class="contact-input" placeholder="关系（如儿子）"
                 value="{{item.relation}}" bindinput="onContactInput" data-index="{{index}}" data-field="relation" />
        </view>
        <view class="contact-delete" bindtap="deleteContact" data-index="{{index}}">
          <text>删除</text>
        </view>
      </view>

      <view wx:if="{{emergencyContacts.length === 0}}" class="no-contact">
        <text>暂未设置紧急联系人</text>
      </view>
    </view>

    <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <!-- 保存按钮 -->
  <view class="save-bar">
    <view class="save-btn" bindtap="handleSave">
      <text>保存信息</text>
    </view>
  </view>
</view>
