.message-page {
  min-height: 100vh;
  background: #FDF8F0;
}

.page-header {
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  background: linear-gradient(135deg, #FCEBD4, #F9DDB8);
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B4513;
}

.message-scroll {
  height: calc(100vh - 200rpx);
  overflow-x: hidden;
}
.scroll-inner {
  padding: 20rpx 30rpx;
}

.msg-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(139,69,19,0.06);
}
.msg-avatar-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.msg-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}
.msg-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #E8573A;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 6rpx;
}
.msg-content {
  flex: 1;
  overflow: hidden;
}
.msg-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.msg-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;
}
.msg-time {
  font-size: 22rpx;
  color: #bbb;
}
.msg-preview {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.system-msg {
  display: flex;
  align-items: flex-start;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}
.system-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.system-content {
  flex: 1;
}
.system-text {
  font-size: 26rpx;
  color: #795548;
  display: block;
  margin-bottom: 6rpx;
}
.system-time {
  font-size: 22rpx;
  color: #bbb;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.alert-section {
  margin: 16rpx 24rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #FFCDD2;
}

.alert-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.alert-icon {
  width: 28rpx;
  height: 28rpx;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #C62828;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #FFCDD2;
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.alert-dot.danger {
  background: #C62828;
}

.alert-dot.warning {
  background: #F57C00;
}

.alert-content {
  flex: 1;
}

.alert-text {
  font-size: 26rpx;
  color: #C62828;
  display: block;
  margin-bottom: 4rpx;
}

.alert-time {
  font-size: 20rpx;
  color: #E57373;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #ccc;
}
