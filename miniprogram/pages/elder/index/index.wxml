<view class="elder-page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left">
      <view class="avatar-wrap" bindtap="goMine">
        <image class="avatar" src="{{userInfo.avatar || '/static/images/default-avatar.svg'}}" mode="aspectFill" />
      </view>
    </view>
    <view class="header-center">
      <text class="header-title">语音交流入口</text>
    </view>
    <view class="header-right">
      <view class="bell-wrap" bindtap="goMessage">
        <image class="bell-icon" src="/static/icons/bell.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        <view wx:if="{{unreadCount > 0}}" class="badge">{{unreadCount}}</view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll" enhanced show-scrollbar="{{false}}">
    <view class="scroll-inner">
    <!-- 公益公告轮播 -->
    <view wx:if="{{announcements.length > 0}}" class="swiper-wrap">
      <swiper class="announcement-swiper" autoplay circular interval="{{4000}}"
              bindchange="onSwiperChange">
        <swiper-item wx:for="{{announcements}}" wx:key="_id">
          <view class="swiper-item-card">
            <text class="swiper-tag">{{item.type === 'activity' ? '公益活动' : '公告'}}</text>
            <text class="swiper-title">{{item.title}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view class="swiper-dots">
        <view wx:for="{{announcements}}" wx:key="_id"
              class="dot {{currentSwiperIndex === index ? 'active' : ''}}"></view>
      </view>
    </view>

    <!-- 功能卡片区域 - 仿设计稿布局 -->
    <view class="func-grid">
      <!-- 语音交流大卡片（左侧） -->
      <view class="voice-card" bindtap="goVoiceChat">
        <text class="voice-title">"语音交流"</text>
        <text class="voice-sub">每日忆交流工具</text>
        <view class="voice-bottom">
          <image class="voice-heart" src="/static/icons/heart.svg" mode="aspectFit" style="width:32rpx;height:32rpx;" />
        </view>
      </view>
      <!-- 右侧两个小卡片 -->
      <view class="func-right-col">
        <view class="course-card" bindtap="goCourseList">
          <text class="small-card-title">银发课堂</text>
          <text class="small-card-sub">学习使用教程</text>
        </view>
        <view class="study-card" bindtap="goStudy">
          <view class="study-content">
            <text class="small-card-title">学习</text>
            <text class="small-card-sub">学习模块</text>
          </view>
          <image class="study-emoji" src="/static/icons/book.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        </view>
      </view>
    </view>

    <!-- 四个超大圆形快捷入口按钮 -->
    <view class="quick-entry-card">
      <view class="quick-item" bindtap="goCreateOrder">
        <view class="quick-circle q-help">
          <image class="q-icon" src="/static/icons/clipboard.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        </view>
        <text class="quick-label">我要求助</text>
      </view>
      <view class="quick-item" bindtap="goHealth">
        <view class="quick-circle q-health">
          <image class="q-icon" src="/static/icons/heartbeat.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        </view>
        <text class="quick-label">健康数据</text>
      </view>
      <view class="quick-item" bindtap="goShop">
        <view class="quick-circle q-shop">
          <image class="q-icon" src="/static/icons/clipboard.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        </view>
        <text class="quick-label">便民商城</text>
      </view>
      <view class="quick-item" bindtap="handleSOS">
        <view class="quick-circle q-sos">
          <image class="q-icon" src="/static/icons/sos.svg" mode="aspectFit" style="width:44rpx;height:44rpx;" />
        </view>
        <text class="quick-label">紧急呼救</text>
      </view>
    </view>

    <!-- 结对志愿者快捷展示 -->
    <view wx:if="{{pairedVolunteer}}" class="paired-card" bindtap="goPairDetail">
      <image class="paired-avatar" src="{{pairedVolunteer.avatar || '/static/images/default-avatar.svg'}}" mode="aspectFill" />
      <view class="paired-info">
        <text class="paired-name">我的志愿者：{{pairedVolunteer.name}}</text>
        <text class="paired-phone"><image class="inline-icon" src="/static/icons/phone.svg" mode="aspectFit" /> {{pairedVolunteer.phone}}</text>
      </view>
      <view class="paired-call" catchtap="callVolunteer">
        <image class="call-text" src="/static/icons/phone.svg" mode="aspectFit" style="width:32rpx;height:32rpx;" />
      </view>
    </view>

    <!-- 今日健康简易卡片 -->
    <view class="health-card" bindtap="goHealth">
      <view class="health-header">
        <text class="health-title">今日健康</text>
        <view class="health-more">查看详情 <image class="more-arrow" src="/static/icons/arrow-right.svg" mode="aspectFit" /></view>
      </view>
      <view class="health-data">
        <view class="health-item">
          <text class="health-value">{{healthData.bloodPressure || '--/--'}}</text>
          <text class="health-label">血压 mmHg</text>
        </view>
        <view class="health-divider"></view>
        <view class="health-item">
          <text class="health-value">{{healthData.heartRate || '--'}}</text>
          <text class="health-label">心率 bpm</text>
        </view>
        <view class="health-divider"></view>
        <view class="health-item">
          <text class="health-value">{{healthData.bloodOxygen || '--'}}</text>
          <text class="health-label">血氧 %</text>
        </view>
      </view>
    </view>

    <!-- 心愿墙 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">心愿墙</text>
        <view class="section-more" bindtap="goCreateOrder">需求发布 <image class="more-arrow" src="/static/icons/arrow-right.svg" mode="aspectFit" /></view>
      </view>
      <view class="wish-list">
        <view class="wish-item" wx:for="{{wishList}}" wx:key="_id" bindtap="goOrderDetail" data-id="{{item._id}}">
          <image class="wish-cover" src="{{item.elderAvatar || '/static/images/default-avatar.svg'}}" mode="aspectFill" />
          <view class="wish-info">
            <text class="wish-name">{{item.title || '需求发布'}}</text>
            <text class="wish-desc">{{item.description}}</text>
            <view class="wish-meta">
              <view class="wish-stars">
                <text wx:for="{{5}}" wx:key="*this" wx:for-item="s" wx:for-index="idx"
                      class="star {{idx < (item.urgency || 3) ? 'active' : ''}}"><image class="star-icon" src="{{idx < (item.urgency || 3) ? '/static/icons/star-filled.svg' : '/static/icons/star.svg'}}" mode="aspectFit" /></text>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{wishList.length === 0}}" class="empty-wish">
          <image class="empty-icon" src="/static/icons/edit.svg" mode="aspectFit" style="width:64rpx;height:64rpx;" />
          <text class="empty-text">暂无心愿，点击右上角发布</text>
        </view>
      </view>
    </view>

    <!-- 一键求助超大按钮 -->
    <view class="sos-wrapper">
      <view class="sos-btn" bindtap="handleSOS">
        <text class="sos-text">一键求助</text>
      </view>
    </view>

    <view class="bottom-space"></view>
    </view>
  </scroll-view>
</view>
