.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.detail-img {
  width: 100%;
  height: 560rpx;
  background: #f0f0f0;
}

.detail-card {
  background: #fff;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}
.detail-price-sym {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8573A;
}
.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #E8573A;
}
.detail-spec {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  line-height: 1.4;
}
.detail-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
  line-height: 1.5;
}

.info-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #999;
}
.info-value {
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  gap: 20rpx;
  z-index: 100;
}
.btn-contact {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  font-size: 22rpx;
  color: #666;
}
.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}
.btn-buy {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2DB5A0, #3BC4B1);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  height: 88rpx;
}
.btn-buy.disabled {
  background: #ccc;
}

/* 下单面板 */
.panel-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.order-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.order-panel.show {
  transform: translateY(0);
}
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.panel-title {
  font-size: 34rpx;
  font-weight: 600;
}
.panel-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
}

.panel-goods {
  display: flex;
  gap: 20rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.panel-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}
.panel-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.panel-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.panel-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #E8573A;
  margin-top: 12rpx;
}

.panel-qty {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.qty-label {
  font-size: 30rpx;
  color: #333;
}
.qty-control {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.qty-num {
  width: 80rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}

.panel-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}
.total-label {
  font-size: 30rpx;
  color: #666;
}
.total-price {
  font-size: 42rpx;
  font-weight: 700;
  color: #E8573A;
}

.panel-buy-btn {
  background: linear-gradient(135deg, #2DB5A0, #3BC4B1);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
  margin-top: 16rpx;
}

/* 支付弹窗 */
.pay-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 300;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.pay-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.pay-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  z-index: 301;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}
.pay-dialog.show {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, -50%) scale(1);
}

.pay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 48rpx;
}
.pay-loading {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top: 6rpx solid #2DB5A0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

.pay-success-icon {
  width: 100rpx;
  height: 100rpx;
  background: #2DB5A0;
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.pay-fail-icon {
  width: 100rpx;
  height: 100rpx;
  background: #E8573A;
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.pay-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-top: 24rpx;
}
.pay-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #E8573A;
  margin-top: 12rpx;
}
.pay-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.pay-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
  width: 100%;
}
.pay-btn-secondary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 40rpx;
}
.pay-btn-primary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #fff;
  background: #2DB5A0;
  border-radius: 40rpx;
  font-weight: 600;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
}
.loading-state {
  text-align: center;
  padding: 200rpx 0;
  font-size: 28rpx;
  color: #999;
}
