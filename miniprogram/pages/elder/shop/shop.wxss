.shop-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 30rpx;
}

.shop-header {
  background: linear-gradient(135deg, #2DB5A0, #3BC4B1);
  padding: 40rpx 32rpx 48rpx;
  color: #fff;
}
.shop-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}
.shop-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  display: block;
}

.category-bar {
  display: flex;
  padding: 24rpx 24rpx 20rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  margin-top: -20rpx;
}
.cat-item {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #fff;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.cat-item.active {
  background: #2DB5A0;
  color: #fff;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}
.goods-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.goods-img {
  width: 100%;
  height: 280rpx;
  background: #f0f0f0;
}
.goods-info {
  padding: 16rpx 20rpx 20rpx;
}
.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.goods-spec {
  font-size: 22rpx;
  color: #2DB5A0;
  margin-top: 4rpx;
  display: block;
}
.goods-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.goods-price {
  display: flex;
  align-items: baseline;
}
.price-sym {
  font-size: 24rpx;
  font-weight: 600;
  color: #E8573A;
}
.price-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #E8573A;
}
.goods-stock {
  font-size: 20rpx;
  color: #bbb;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  width: 96rpx;
  height: 96rpx;
  opacity: 0.4;
}
.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-top: 16rpx;
}
.loading-state {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}
