.pair-page {
  min-height: 100vh;
  background: #FDF8F0;
}
.page-header {
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  background: linear-gradient(135deg, #FCEBD4, #F9DDB8);
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B4513;
}

.paired-section {
  padding: 30rpx;
}
.volunteer-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,69,19,0.08);
  margin-bottom: 24rpx;
}
.vol-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE0B2;
  margin-right: 24rpx;
}
.vol-info {
  flex: 1;
}
.vol-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #5D4037;
  display: block;
  margin-bottom: 8rpx;
}
.vol-badge {
  font-size: 24rpx;
  color: #E8573A;
  margin-bottom: 6rpx;
}
.vol-hours {
  font-size: 24rpx;
  color: #999;
}

.action-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.call-btn {
  background: linear-gradient(135deg, #E8573A, #D42A1A);
}
.chat-btn {
  background: linear-gradient(135deg, #FFE0B2, #FFCC80);
}
.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
}
.call-btn .action-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}
.chat-btn .action-text {
  color: #5D4037;
  font-size: 26rpx;
  font-weight: 600;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 4rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(139,69,19,0.06);
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f0e8;
}
.info-item:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #999;
}
.info-value {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
}

.empty-pair {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}
.empty-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
}
.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 16rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.service-record-section {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.record-list {
  padding-left: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF8A50;
  flex-shrink: 0;
}

.record-content {
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.record-date {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.record-rating {
  display: flex;
  gap: 2rpx;
}

.mini-star {
  width: 22rpx;
  height: 22rpx;
}

.no-records {
  text-align: center;
  padding: 24rpx;
  color: #ccc;
  font-size: 26rpx;
}
