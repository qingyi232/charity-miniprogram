.sos-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFEBEE, #FDF8F0);
}
.sos-header {
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  text-align: center;
}
.sos-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #C62828;
}

.sos-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
}

.sos-big-btn {
  margin: 30rpx 0;
}
.sos-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8573A, #C62828);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(198,40,40,0.4);
  transition: transform 0.2s;
}
.sos-circle.pressing {
  transform: scale(0.92);
}
.sos-circle:active {
  transform: scale(0.92);
}
.sos-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}
.sos-label {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}
.sos-hint {
  font-size: 28rpx;
  color: #C62828;
  font-weight: 600;
  margin-top: 20rpx;
}
.sos-sub-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  margin-bottom: 30rpx;
}

/* 健康数据概况 */
.health-summary {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.hs-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 16rpx;
}
.hs-row {
  display: flex;
  justify-content: space-around;
}
.hs-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hs-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2DB5A0;
  margin-bottom: 4rpx;
}
.hs-value.alert {
  color: #C62828;
}
.hs-label {
  font-size: 22rpx;
  color: #999;
}

/* 紧急联系人 */
.emergency-contacts {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.ec-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.ec-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;
}
.ec-add {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #2DB5A0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #E6F7F4;
}
.ec-add-icon {
  width: 24rpx;
  height: 24rpx;
}
.ec-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.ec-item:last-child {
  border-bottom: none;
}
.ec-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.ec-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.ec-relation {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}
.ec-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ec-phone {
  font-size: 26rpx;
  color: #4A90D9;
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.inline-icon {
  width: 24rpx;
  height: 24rpx;
}
.ec-delete {
  font-size: 22rpx;
  color: #E8573A;
  padding: 4rpx 12rpx;
  border: 1rpx solid #E8573A;
  border-radius: 12rpx;
}
.ec-empty {
  text-align: center;
  padding: 20rpx;
  color: #ccc;
  font-size: 26rpx;
}

/* 快捷拨号 */
.quick-call {
  display: flex;
  gap: 24rpx;
  width: 100%;
}
.call-119, .call-110 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.call-119 {
  background: #fff;
  border: 2rpx solid #E8573A;
}
.call-110 {
  background: #fff;
  border: 2rpx solid #4A90D9;
}
.call-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}
.call-119 .call-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8573A;
}
.call-110 .call-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A90D9;
}

/* 自定义弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}
.modal-dialog {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}
.modal-field {
  margin-bottom: 24rpx;
}
.modal-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}
.modal-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.modal-btn.confirm {
  background: #2DB5A0;
  color: #fff;
}
