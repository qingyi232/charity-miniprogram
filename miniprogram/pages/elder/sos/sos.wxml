<view class="sos-page">
  <view class="sos-header">
    <text class="sos-title">紧急呼救</text>
  </view>

  <view class="sos-content">
    <view class="sos-big-btn" bindtap="handleSOS">
      <view class="sos-circle {{pressing ? 'pressing' : ''}}">
        <image class="sos-icon" src="/static/icons/sos.svg" mode="aspectFit" />
        <text class="sos-label">紧急求助</text>
      </view>
    </view>
    <text class="sos-hint">点击按钮发送紧急求助信号</text>
    <text class="sos-sub-hint">将通知您的结对志愿者和管理员</text>

    <!-- 当前健康概况 -->
    <view class="health-summary" wx:if="{{latestHealth}}">
      <view class="hs-title">当前健康数据</view>
      <view class="hs-row">
        <view class="hs-item">
          <text class="hs-value {{latestHealth.bpAlert ? 'alert' : ''}}">{{latestHealth.bp}}</text>
          <text class="hs-label">血压</text>
        </view>
        <view class="hs-item">
          <text class="hs-value">{{latestHealth.heartRate}}</text>
          <text class="hs-label">心率</text>
        </view>
        <view class="hs-item">
          <text class="hs-value {{latestHealth.boAlert ? 'alert' : ''}}">{{latestHealth.bloodOxygen}}</text>
          <text class="hs-label">血氧%</text>
        </view>
      </view>
    </view>

    <!-- 紧急联系人 -->
    <view class="emergency-contacts">
      <view class="ec-header">
        <text class="ec-title">紧急联系人</text>
        <view class="ec-add" bindtap="addContact">
          <image class="ec-add-icon" src="/static/icons/plus.svg" mode="aspectFit" />
          <text>添加</text>
        </view>
      </view>
      <view class="ec-item" wx:for="{{emergencyContacts}}" wx:key="phone">
        <view class="ec-info">
          <text class="ec-name">{{item.name}}</text>
          <text class="ec-relation">{{item.relation || ''}}</text>
        </view>
        <view class="ec-actions">
          <text class="ec-phone" bindtap="callContact" data-phone="{{item.phone}}">
            <image class="inline-icon" src="/static/icons/phone.svg" mode="aspectFit" /> {{item.phone}}
          </text>
          <view class="ec-delete" catchtap="deleteContact" data-index="{{index}}">
            <text>删除</text>
          </view>
        </view>
      </view>
      <view wx:if="{{emergencyContacts.length === 0}}" class="ec-empty">
        <text>暂未设置紧急联系人，点击右上角添加</text>
      </view>
    </view>

    <!-- 快捷拨号 -->
    <view class="quick-call">
      <view class="call-119" bindtap="call120">
        <image class="call-icon" src="/static/icons/ambulance.svg" mode="aspectFit" />
        <text class="call-text">拨打 120</text>
      </view>
      <view class="call-110" bindtap="call110">
        <image class="call-icon" src="/static/icons/police.svg" mode="aspectFit" />
        <text class="call-text">拨打 110</text>
      </view>
    </view>
  </view>

  <!-- 添加紧急联系人弹窗 -->
  <view class="modal-mask" wx:if="{{showContactModal}}" catchtap="closeContactModal">
    <view class="modal-dialog" catchtap="">
      <view class="modal-title">添加紧急联系人</view>
      <view class="modal-field">
        <text class="modal-label">姓名</text>
        <input class="modal-input" placeholder="请输入姓名" value="{{contactForm.name}}" bindinput="onContactInput" data-field="name" />
      </view>
      <view class="modal-field">
        <text class="modal-label">手机号</text>
        <input class="modal-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{contactForm.phone}}" bindinput="onContactInput" data-field="phone" />
      </view>
      <view class="modal-field">
        <text class="modal-label">关系</text>
        <input class="modal-input" placeholder="如：子女、配偶、邻居" value="{{contactForm.relation}}" bindinput="onContactInput" data-field="relation" />
      </view>
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="closeContactModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmAddContact">确定</view>
      </view>
    </view>
  </view>
</view>
