.mine-page {
  min-height: 100vh;
  background: #FDF8F0;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
  background: linear-gradient(135deg, #FCEBD4, #F9DDB8);
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.1);
  margin-right: 24rpx;
}
.user-info {
  flex: 1;
}
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B4513;
  display: block;
  margin-bottom: 8rpx;
}
.user-phone {
  font-size: 26rpx;
  color: #A0522D;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(139,69,19,0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f0e8;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #5D4037;
}
.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.logout-wrapper {
  padding: 60rpx 30rpx;
}
.logout-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  border: 2rpx solid #E8573A;
  color: #E8573A;
  font-size: 30rpx;
}
