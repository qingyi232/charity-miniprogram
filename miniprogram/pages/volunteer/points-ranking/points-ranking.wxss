.ranking-page { min-height: 100vh; background: #f5f5f5; }
.ranking-header {
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  color: #fff;
}
.ranking-title { font-size: 40rpx; font-weight: 700; display: block; }
.ranking-sub { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 8rpx; }
.ranking-list { padding: 20rpx 24rpx; }
.ranking-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.ranking-item.top { border-left: 6rpx solid #FF6B35; }
.rank-num {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #999;
  background: #f0f0f0;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.rank-1 { background: #FFD700; color: #fff; }
.rank-2 { background: #C0C0C0; color: #fff; }
.rank-3 { background: #CD7F32; color: #fff; }
.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.rank-info { flex: 1; }
.rank-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.rank-hours { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.rank-points { text-align: right; }
.rank-points-num { font-size: 34rpx; font-weight: 700; color: #FF6B35; display: block; }
.rank-points-label { font-size: 20rpx; color: #999; display: block; }
.empty-state { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
