.order-page {
  min-height: 100vh;
  background: #F2F8F6;
}

.page-header {
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.tab-bar-filter {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #fff;
}
.tab-bar-filter .tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}
.tab-bar-filter .tab-item.active {
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  color: #fff;
  font-weight: 600;
}

.sort-bar {
  display: flex;
  padding: 12rpx 24rpx;
  gap: 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}
.sort-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
  color: #999;
  position: relative;
}
.sort-item.active {
  color: #2DB5A0;
  font-weight: 600;
}
.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #2DB5A0;
  border-radius: 2rpx;
}
.sort-icon {
  width: 24rpx;
  height: 24rpx;
}

.distance-tag {
  display: inline-block;
  background: #E6F7F4;
  color: #2DB5A0;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 6rpx;
}

.order-scroll {
  height: calc(100vh - 280rpx);
  overflow-x: hidden;
}
.scroll-inner {
  padding: 20rpx 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}
.order-left {
  flex-shrink: 0;
}
.order-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
}
.order-info {
  flex: 1;
}
.order-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.order-address {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}
.order-time {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-bottom: 8rpx;
}
.order-stars {
  display: flex;
}
.order-stars .star {
  opacity: 0.25;
}
.order-stars .star.active {
  opacity: 1;
}
.order-stars .star .star-icon {
  width: 26rpx;
  height: 26rpx;
}
.order-action {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}
.accept-btn {
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(43,181,160,0.25);
}
.accept-btn:active {
  opacity: 0.85;
}
.detail-btn {
  background: #E6F7F4;
  color: #2DB5A0;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-weight: 500;
}
.status-tag {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

/* 主分类Tab */
.main-tab-bar {
  display: flex;
  padding: 16rpx 24rpx 0;
  gap: 0;
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
}
.main-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}
.main-tab.active {
  color: #fff;
  font-weight: 700;
  border-bottom-color: #fff;
}

/* 代购配送卡片 */
.shop-card .shop-img {
  border-radius: 12rpx;
}
.shop-price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.shop-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #E8573A;
}
.shop-qty {
  font-size: 24rpx;
  color: #999;
}
.shop-elder-name {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}
.shop-status-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #999;
}
.shop-status-tag.status-pending_accept {
  background: #FFF3E6;
  color: #F5A623;
}
.shop-status-tag.status-accepted {
  background: #E6F7F4;
  color: #2DB5A0;
}
.shop-status-tag.status-delivering {
  background: #E6F0FF;
  color: #4A90D9;
}
.shop-status-tag.status-delivered,
.shop-status-tag.status-completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.inline-icon {
  width: 22rpx;
  height: 22rpx;
  vertical-align: middle;
  margin-right: 4rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #ccc;
}
