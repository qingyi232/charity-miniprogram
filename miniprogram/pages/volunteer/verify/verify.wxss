.verify-page {
  min-height: 100vh;
  background: #F2F8F6;
  padding-bottom: env(safe-area-inset-bottom);
}

.verified-banner, .pending-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}
.v-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}
.verified-banner .v-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #2DB5A0;
}
.pending-banner .v-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #F5A623;
}
.v-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.form-area {
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 16rpx;
  padding-left: 8rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.required {
  color: #E8573A;
}
.form-input {
  width: 100%;
  min-height: 88rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
  line-height: 1.5;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: #2DB5A0;
  background: #fff;
}
.form-textarea {
  width: 100%;
  min-height: 140rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.type-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.type-tag {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.type-tag.active {
  background: #E6F7F4;
  color: #2DB5A0;
  border-color: #2DB5A0;
}

.notice-box {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx 0;
}
.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F57C00;
  display: block;
  margin-bottom: 12rpx;
}
.notice-text {
  font-size: 24rpx;
  color: #A0522D;
  display: block;
  line-height: 1.8;
}

.submit-area {
  padding: 24rpx 0 48rpx;
}
.submit-btn {
  width: 100% !important;
  background: linear-gradient(135deg, #43B89C, #2DB5A0) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 44rpx !important;
  padding: 24rpx 0 !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 8rpx 24rpx rgba(45,181,160,0.3);
}
.submit-btn[disabled] {
  background: #ccc !important;
  box-shadow: none;
}
