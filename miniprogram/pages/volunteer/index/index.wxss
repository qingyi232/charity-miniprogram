.volunteer-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F2F8F6;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  max-width: 100vw;
}

/* ========== 顶部青绿渐变区 ========== */
.header-bg {
  background: linear-gradient(160deg, #43B89C 0%, #2DB5A0 50%, #20A88E 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 88rpx);
  border-radius: 0 0 40rpx 40rpx;
  padding-bottom: 36rpx;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.msg-btn {
  position: relative;
  padding: 6rpx;
}
.msg-icon {
  width: 40rpx;
  height: 40rpx;
}
.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #FF4444;
  color: #fff;
  font-size: 18rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  padding: 0 4rpx;
}
.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.5);
}

/* 大横幅 */
.banner-card {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.banner-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.banner-subtitle {
  font-size: 34rpx;
  color: rgba(255,255,255,0.9);
  display: block;
}
.banner-illust {
  width: 80rpx;
  height: 80rpx;
}

.content-scroll {
  flex: 1;
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}
.scroll-inner {
  padding: 20rpx 24rpx;
}

/* ========== 服务统计条 ========== */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(43,181,160,0.08);
}
.stats-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}
.stats-hours {
  font-size: 40rpx;
  font-weight: 700;
  color: #2DB5A0;
}
.stats-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}
.stats-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.star-badge {
  width: 36rpx;
  height: 36rpx;
}
.star-text {
  font-size: 26rpx;
  color: #2DB5A0;
  font-weight: 600;
}

/* ========== 区块标题 ========== */
.section {
  margin-bottom: 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.section-more {
  font-size: 26rpx;
  color: #2DB5A0;
  font-weight: 500;
  display: flex;
  align-items: center;
}

/* ========== 订单卡片（仿设计稿） ========== */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  position: relative;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}
.order-photo {
  width: 160rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  object-fit: cover;
}
.order-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.order-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.order-addr {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}
.order-stars {
  display: flex;
  margin-bottom: 8rpx;
}
.star {
  margin-right: 2rpx;
  opacity: 0.25;
}
.star.active {
  opacity: 1;
}
.star .star-icon {
  width: 26rpx;
  height: 26rpx;
}
.order-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.order-category {
  font-size: 20rpx;
  color: #2DB5A0;
  background: #E6F7F4;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.order-time {
  font-size: 20rpx;
  color: #bbb;
}
.order-action-col {
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}
.view-btn {
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(43,184,156,0.3);
}
.view-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.empty-emoji {
  width: 60rpx;
  height: 60rpx;
}
.empty-text {
  color: #ccc;
  font-size: 28rpx;
}

/* ========== 结对老人列表 ========== */
.pair-list {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}
.pair-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  width: calc(25% - 15rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.pair-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  border: 2rpx solid #E6F7F4;
}
.pair-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}
.empty-pair {
  text-align: center;
  padding: 30rpx;
  color: #ccc;
  font-size: 26rpx;
  width: 100%;
}

/* ========== 服务统计面板 ========== */
.service-stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.service-stats-header {
  margin-bottom: 24rpx;
}
.service-stats-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}
.service-stats-grid {
  display: flex;
  justify-content: space-around;
}
.service-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.service-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2DB5A0;
  margin-bottom: 8rpx;
}
.service-stat-label {
  font-size: 22rpx;
  color: #999;
}

.activity-preview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #F8FFFE;
  border-radius: 12rpx;
}

.activity-tag {
  font-size: 20rpx;
  color: #1565C0;
  background: #E3F2FD;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.activity-title {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.activity-date {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.reject-btn {
  background: #fff;
  border: 2rpx solid #E53935;
  border-radius: 12rpx;
  padding: 8rpx 20rpx;
  margin-top: 8rpx;
}
.reject-btn text {
  color: #E53935;
  font-size: 24rpx;
}
.order-duration {
  font-size: 20rpx;
  color: #2DB5A0;
  background: #E8F5E9;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.filter-item {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  flex-shrink: 0;
}
.filter-item.active {
  background: #2DB5A0;
  color: #fff;
}
.order-card.urgent {
  border-left: 6rpx solid #E53935;
}
.urgent-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #E53935;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
  z-index: 1;
}

.bottom-space {
  height: calc(130rpx + env(safe-area-inset-bottom));
}

.today-remind {
  margin: 0 24rpx 20rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #FFB300;
}
.remind-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.remind-title { font-size: 26rpx; font-weight: 600; color: #F57F17; }
.remind-count { font-size: 22rpx; color: #FFB300; }
.remind-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.remind-time { font-size: 24rpx; color: #666; width: 100rpx; flex-shrink: 0; }
.remind-name { font-size: 26rpx; color: #333; flex: 1; }
.remind-cat { font-size: 20rpx; color: #999; background: #f0f0f0; padding: 4rpx 12rpx; border-radius: 12rpx; flex-shrink: 0; }

.case-preview { padding: 0; }
.case-preview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 10rpx;
}
.case-p-title { font-size: 26rpx; color: #333; font-weight: 500; }
.case-p-community { font-size: 22rpx; color: #999; }

.dashboard-card {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.dash-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.dash-grid {
  display: flex;
  text-align: center;
}
.dash-item {
  flex: 1;
}
.dash-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2DB5A0;
}
.dash-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.dash-supply-demand {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.dash-sd-title { font-size: 24rpx; color: #666; display: block; margin-bottom: 12rpx; }
.dash-sd-row { display: flex; gap: 16rpx; }
.dash-sd-item {
  flex: 1;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
}
.sd-label { font-size: 22rpx; color: #999; display: block; }
.sd-val { font-size: 24rpx; font-weight: 600; display: block; margin-top: 6rpx; }
.sd-val.demand { color: #E53935; }
.sd-val.supply { color: #2DB5A0; }

.dash-top3 {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.dash-top3-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}
.top3-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.top3-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.top3-rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #2DB5A0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  line-height: 36rpx;
  flex-shrink: 0;
}
.top3-name {
  font-size: 24rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}
.top3-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}
.top3-bar {
  height: 100%;
  background: linear-gradient(90deg, #2DB5A0, #4ECDC4);
  border-radius: 8rpx;
}
.top3-count {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ========== Custom Input Modal ========== */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.modal-dialog {
  position: relative;
  z-index: 1;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 0;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-textarea {
  width: 100%;
  min-height: 200rpx;
  max-height: 400rpx;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  box-sizing: border-box;
  line-height: 1.6;
  background: #fafafa;
}
.modal-actions {
  display: flex;
  border-top: 1rpx solid #eee;
  margin: 30rpx -36rpx 0;
}
.modal-cancel, .modal-confirm {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
}
.modal-cancel {
  color: #999;
  border-right: 1rpx solid #eee;
}
.modal-confirm {
  color: #2DB5A0;
  font-weight: 600;
}
.modal-confirm-danger {
  color: #E53935;
}
