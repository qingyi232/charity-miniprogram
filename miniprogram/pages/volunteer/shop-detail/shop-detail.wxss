.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}
.detail-img {
  width: 100%;
  height: 560rpx;
  background: #e8e8e8;
}
.detail-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.detail-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #FF6B35;
}
.detail-price-unit {
  font-size: 26rpx;
  color: #FF6B35;
  margin-left: 6rpx;
}
.detail-exchanged {
  font-size: 22rpx;
  color: #999;
  margin-left: auto;
}
.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.detail-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}
.detail-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.section-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.notice-item {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}
.stock-info {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}
.stock-label {
  font-size: 26rpx;
  color: #666;
}
.stock-value {
  font-size: 26rpx;
  color: #2DB5A0;
  font-weight: 600;
}
.stock-value.out {
  color: #ccc;
}
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.my-points {
  display: flex;
  flex-direction: column;
  margin-right: 30rpx;
}
.my-points-label {
  font-size: 22rpx;
  color: #999;
}
.my-points-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B35;
}
.exchange-btn {
  flex: 1;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E) !important;
  color: #fff !important;
  border-radius: 50rpx !important;
  padding: 24rpx 0 !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  border: none !important;
}
.exchange-btn.disabled {
  background: #ccc !important;
}
.error-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}
