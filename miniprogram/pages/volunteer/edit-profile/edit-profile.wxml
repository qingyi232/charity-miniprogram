<view class="edit-page">
  <view class="avatar-section" bindtap="chooseAvatar">
    <image class="edit-avatar" src="{{form.avatar || '/static/images/default-avatar.svg'}}" mode="aspectFill" />
    <text class="avatar-tip">点击更换头像</text>
  </view>

  <view class="form-area">
    <view class="form-group">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{form.nickname}}" bindinput="onInput" data-field="nickname" />
    </view>

    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-group">
      <text class="form-label">年龄</text>
      <input class="form-input" type="number" placeholder="请输入年龄" value="{{form.age}}" bindinput="onInput" data-field="age" />
    </view>

    <view class="form-group">
      <text class="form-label">服务区域</text>
      <input class="form-input" placeholder="例：xx市xx区xx街道" value="{{form.serviceArea}}" bindinput="onInput" data-field="serviceArea" />
    </view>

    <view class="form-group">
      <text class="form-label">擅长服务类型</text>
      <view class="type-tags">
        <view class="type-tag {{form.serviceTypes.indexOf('escort') >= 0 ? 'active' : ''}}" bindtap="toggleType" data-type="escort">陪护照料</view>
        <view class="type-tag {{form.serviceTypes.indexOf('shopping') >= 0 ? 'active' : ''}}" bindtap="toggleType" data-type="shopping">生活代购</view>
        <view class="type-tag {{form.serviceTypes.indexOf('medical') >= 0 ? 'active' : ''}}" bindtap="toggleType" data-type="medical">就医陪同</view>
        <view class="type-tag {{form.serviceTypes.indexOf('housework') >= 0 ? 'active' : ''}}" bindtap="toggleType" data-type="housework">家务帮忙</view>
        <view class="type-tag {{form.serviceTypes.indexOf('chat') >= 0 ? 'active' : ''}}" bindtap="toggleType" data-type="chat">日常聊天</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">个人简介</text>
      <textarea class="form-textarea" placeholder="介绍一下自己（选填）" value="{{form.bio}}" bindinput="onInput" data-field="bio" maxlength="200" />
    </view>
  </view>

  <view class="save-area">
    <button class="save-btn" bindtap="handleSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存修改'}}
    </button>
  </view>
</view>
