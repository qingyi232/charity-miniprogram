.service-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F2F8F6;
  overflow: hidden;
}

/* ========== Header ========== */
.page-header-bg {
  background: linear-gradient(160deg, #43B89C 0%, #2DB5A0 50%, #20A88E 100%);
  padding: 20rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  border-radius: 0 0 40rpx 40rpx;
  padding-bottom: 36rpx;
}
.page-header-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 20rpx;
}
.points-card {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
}
.points-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}
.points-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 20rpx;
}
.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.points-main {
  display: flex;
  flex-direction: column;
}
.points-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
}
.points-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.points-badges {
  display: flex;
  gap: 12rpx;
}
.badge-svg {
  width: 48rpx;
  height: 48rpx;
}

/* ========== Section Card ========== */
.service-scroll {
  flex: 1;
  overflow-x: hidden;
}
.scroll-inner {
  padding: 20rpx 24rpx;
}
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.section-card-header {
  margin-bottom: 20rpx;
}
.section-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

/* ========== Volunteer Info ========== */
.volunteer-info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.vol-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #E6F7F4;
  flex-shrink: 0;
}
.vol-detail {
  flex: 1;
}
.vol-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}
.vol-level {
  font-size: 24rpx;
  color: #2DB5A0;
}
.vol-points-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #E6F7F4;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}
.badge-icon-sm {
  width: 28rpx;
  height: 28rpx;
}
.badge-pts {
  font-size: 24rpx;
  font-weight: 600;
  color: #2DB5A0;
}

/* ========== Points Rules ========== */
.points-rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.points-rule-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.rule-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.rule-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
}
.rule-pts {
  font-size: 26rpx;
  color: #2DB5A0;
  font-weight: 600;
}

/* ========== Stats Overview ========== */
.stats-overview {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2DB5A0;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
}
.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #E6F7F4;
}

/* ========== Service Records ========== */
.record-card {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.record-header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}
.record-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.tag-supplement {
  background: #FFF3E0;
  color: #F57C00;
}
.tag-checkin {
  background: #E3F2FD;
  color: #1976D2;
}
.record-date {
  font-size: 22rpx;
  color: #bbb;
}
.record-body {
  margin-bottom: 10rpx;
}
.record-content {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
  line-height: 1.5;
}
.record-elder, .record-category {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}
.record-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.status-approved {
  background: #E8F5E9;
  color: #2E7D32;
}
.status-pending {
  background: #FFF8E1;
  color: #F9A825;
}
.status-rejected {
  background: #FFEBEE;
  color: #C62828;
}
.status-checkin {
  background: #E3F2FD;
  color: #1976D2;
}
.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.record-rating {
  display: flex;
  gap: 4rpx;
}
.record-rating .star-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.3;
}
.record-rating .star-icon.active {
  opacity: 1;
}
.record-hours {
  font-size: 24rpx;
  color: #2DB5A0;
  font-weight: 600;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.empty-icon {
  width: 60rpx;
  height: 60rpx;
  opacity: 0.4;
}
.empty-text {
  color: #ccc;
  font-size: 28rpx;
}

.period-tabs {
  display: flex;
  gap: 8rpx;
}

.period-tab {
  font-size: 22rpx;
  color: #999;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.period-tab.active {
  background: #2DB5A0;
  color: #fff;
}

.period-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.period-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.ps-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2DB5A0;
  margin-bottom: 6rpx;
}

.ps-label {
  font-size: 20rpx;
  color: #999;
}

.archive-section {
  padding: 20rpx;
  text-align: center;
}

.archive-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(43,181,160,0.3);
}

.archive-btn:active {
  opacity: 0.85;
}

.archive-icon {
  width: 36rpx;
  height: 36rpx;
}

.archive-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.archive-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.archive-modal {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.archive-canvas {
  width: 580rpx;
  height: 800rpx;
  display: block;
}

.archive-actions {
  display: flex;
  border-top: 1rpx solid #eee;
}

.archive-save-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  color: #2DB5A0;
  font-size: 30rpx;
  font-weight: 600;
  border-right: 1rpx solid #eee;
}

.archive-close-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  color: #999;
  font-size: 30rpx;
}

.supplement-section {
  margin: 0 24rpx 20rpx;
}
.supplement-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #fff;
  border: 2rpx dashed #2DB5A0;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #2DB5A0;
  font-size: 28rpx;
  font-weight: 500;
}
.supplement-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.bottom-space {
  height: calc(130rpx + env(safe-area-inset-bottom));
}

/* ========== Custom Input Modal ========== */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}
.modal-dialog {
  position: relative;
  z-index: 1;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 0;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 16rpx;
}
.modal-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}
.modal-textarea {
  width: 100%;
  min-height: 200rpx;
  max-height: 400rpx;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  box-sizing: border-box;
  line-height: 1.6;
  background: #fafafa;
}
.modal-actions {
  display: flex;
  border-top: 1rpx solid #eee;
  margin: 30rpx -36rpx 0;
}
.modal-cancel, .modal-confirm {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
}
.modal-cancel {
  color: #999;
  border-right: 1rpx solid #eee;
}
.modal-confirm {
  color: #2DB5A0;
  font-weight: 600;
}
