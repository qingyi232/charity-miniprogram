.shop-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 30rpx;
}

.points-card {
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  color: #fff;
}
.points-bg {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.points-content {
  padding: 36rpx;
  position: relative;
  z-index: 1;
}
.points-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.points-label {
  font-size: 28rpx;
  opacity: 0.9;
}
.points-history {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  opacity: 0.8;
}
.points-history .arrow-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 4rpx;
  filter: brightness(10);
}
.points-number {
  font-size: 72rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}
.points-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}
.points-item {
  flex: 1;
  text-align: center;
}
.p-val {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}
.p-lbl {
  display: block;
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}
.points-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.3);
}

.func-bar {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 0;
}
.func-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}
.func-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.category-bar {
  display: flex;
  padding: 0 24rpx 20rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.cat-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  flex-shrink: 0;
}
.cat-item.active {
  background: #FF6B35;
  color: #fff;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}
.goods-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.goods-img {
  width: 100%;
  height: 280rpx;
  background: #f0f0f0;
}
.goods-info {
  padding: 16rpx 20rpx 20rpx;
}
.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.goods-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.goods-price {
  display: flex;
  align-items: baseline;
}
.price-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #FF6B35;
}
.price-unit {
  font-size: 20rpx;
  color: #FF6B35;
  margin-left: 4rpx;
}
.goods-exchanged {
  font-size: 20rpx;
  color: #bbb;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  width: 96rpx;
  height: 96rpx;
  opacity: 0.4;
}
.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
.loading-state {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #999;
}
