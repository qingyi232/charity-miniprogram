.training-page { min-height: 100vh; background: #f5f5f5; }
.tab-bar-inner {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab.active {
  color: #2DB5A0;
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #2DB5A0;
  border-radius: 2rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 24rpx 12rpx;
}
.course-list { padding: 0 24rpx; }
.course-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
}
.course-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.course-tag.required { background: #FFF3E0; color: #FF9800; }
.course-tag.optional { background: #E8F5E9; color: #4CAF50; }
.course-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; padding-right: 80rpx; }
.course-desc { font-size: 24rpx; color: #888; display: block; margin-bottom: 16rpx; }
.course-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.course-duration { font-size: 22rpx; color: #999; flex-shrink: 0; }
.course-progress-bg {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}
.course-progress {
  height: 100%;
  background: linear-gradient(90deg, #2DB5A0, #4ECDC4);
  border-radius: 6rpx;
}
.course-percent { font-size: 22rpx; color: #2DB5A0; font-weight: 600; flex-shrink: 0; }

.template-list { padding: 0 24rpx; }
.template-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.tpl-icon { width: 48rpx; height: 48rpx; margin-right: 16rpx; flex-shrink: 0; }
.tpl-info { flex: 1; }
.tpl-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tpl-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.tpl-arrow { width: 28rpx; height: 28rpx; opacity: 0.3; flex-shrink: 0; }

.search-bar { padding: 16rpx 24rpx; }
.search-input {
  background: #fff;
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  border: 1rpx solid #e0e0e0;
}
.case-list { padding: 0 24rpx; }
.case-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.case-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; }
.case-summary { font-size: 24rpx; color: #666; display: block; margin-bottom: 12rpx; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.case-tags { display: flex; gap: 8rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.case-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx; background: #E8F5E9; color: #2DB5A0; }
.case-bottom { display: flex; justify-content: space-between; align-items: center; }
.case-community { font-size: 22rpx; color: #999; }
.case-actions { display: flex; gap: 16rpx; }
.action-icon { width: 32rpx; height: 32rpx; }
.expert-list { padding: 20rpx 24rpx; }
.expert-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.expert-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; background: #f0f0f0; }
.expert-info { flex: 1; }
.expert-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.expert-field { font-size: 22rpx; color: #2DB5A0; display: block; margin-top: 4rpx; }
.expert-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.expert-action {
  background: #2DB5A0;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.empty-state { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
