.mine-page {
  min-height: 100vh;
  background: #F2F8F6;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
  background: linear-gradient(135deg, #43B89C, #2DB5A0);
  padding-bottom: 60rpx;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
}
.user-info {
  flex: 1;
}
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.user-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.badge-icon {
  width: 28rpx;
  height: 28rpx;
}
.badge-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}
.service-hours {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hours-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}
.hours-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: -30rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2DB5A0;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}
.verify-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}
.verify-status.verified {
  background: #E6F7F4;
  color: #2DB5A0;
}
.verify-status.unverified {
  background: #FFF3E0;
  color: #F57C00;
}

.logout-wrapper {
  padding: 60rpx 24rpx;
}
.logout-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  border: 2rpx solid #2DB5A0;
  color: #2DB5A0;
  font-size: 30rpx;
  font-weight: 500;
}
.logout-btn:active {
  background: #E6F7F4;
}
